# ============================================
# Arc Network Configuration
# ============================================
ARC_RPC_URL=https://testnet.arc.network
ARC_CHAIN_ID=2025
ARC_EXPLORER=https://explorer.arc.network
ARC_NETWORK_NAME=Arc Testnet

# ============================================
# Circle Integration
# ============================================
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_USDC_ADDRESS=0x1c7d4b196cb0c6f48f42d633da0507f352dfe10
CIRCLE_GATEWAY_URL=https://testnet-api.circle.com
CIRCLE_CCTP_ENABLED=true

# ============================================
# LLM Provider (Claude)
# ============================================
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_MAX_TOKENS=2048

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/agora
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ============================================
# Wallet & Private Keys
# ============================================
PRIVATE_KEY=0x...your_private_key...
PUBLIC_ADDRESS=0x...

# ⚠️  WARNING: Never commit private keys to repo!
# Use AWS Secrets Manager, HashiCorp Vault, or similar in production

# ============================================
# Server Configuration
# ============================================
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-generate-random-256-bit
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

SERVER_HOST=0.0.0.0
SERVER_PORT=5000
WORKERS=4

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_URL=http://localhost:5000/api/v1
REACT_APP_WS_URL=ws://localhost:5000/ws
REACT_APP_CHAIN_ID=2025
REACT_APP_ARC_RPC=https://testnet.arc.network
REACT_APP_USDC_ADDRESS=0x1c7d4b196cb0c6f48f42d633da0507f352dfe10

# ============================================
# External API Keys
# ============================================
# 1inch API (DEX Aggregator)
_1INCH_API_KEY=optional_for_1inch

# Chainlink RPC
CHAINLINK_RPC=https://...

# Etherscan/Block Explorer (optional)
BLOCK_EXPLORER_API_KEY=optional

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ============================================
# Notification Settings
# ============================================
EMAIL_PROVIDER=sendgrid  # or mailgun, smtp
SENDGRID_API_KEY=SG...
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ============================================
# Agent Configuration
# ============================================
AGENT_UPDATE_INTERVAL=300  # 5 minutes in seconds
AGENT_MIN_REBALANCE_AMOUNT=100  # Minimum $100 in USDC
AGENT_SLIPPAGE_TOLERANCE=0.5  # 0.5% max slippage
AGENT_GAS_LIMIT=500000

# ============================================
# Risk Parameters
# ============================================
RISK_VAR_CONFIDENCE=0.95  # 95% confidence level
RISK_DRIFT_THRESHOLD=0.05  # 5% drift triggers rebalance
RISK_MAX_SINGLE_ASSET=0.40  # 40% max allocation per asset
RISK_MIN_TRANSACTION=50  # $50 minimum transaction

# ============================================
# Rebalancing Strategies
# ============================================
STRATEGY_CONSERVATIVE='{"USDC": 0.50, "ETH": 0.30, "BTC": 0.20}'
STRATEGY_BALANCED='{"USDC": 0.30, "ETH": 0.40, "BTC": 0.30}'
STRATEGY_AGGRESSIVE='{"USDC": 0.10, "ETH": 0.50, "BTC": 0.40}'

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============================================
# Monitoring & Analytics
# ============================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_INTERVAL=60

DATADOG_API_KEY=optional
NEW_RELIC_LICENSE_KEY=optional

# ============================================
# Security
# ============================================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=1000

# ============================================
# Feature Flags
# ============================================
FEATURE_MULTI_CHAIN=false
FEATURE_ADVANCED_AI=false
FEATURE_REPUTATION_SYSTEM=false
FEATURE_MOBILE_APP=false

# ============================================
# Development/Testing
# ============================================
TESTING_MODE=false
USE_MOCK_BLOCKCHAIN=false
USE_MOCK_PRICES=false
SEED_TEST_DATA=false
